<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BookShelf{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
    <a class="navbar-brand" href="{{ path('app_book_index') }}">📚 BookShelf</a>
    <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="{{ path('app_book_index') }}">Books</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ path('app_category_index') }}">Categories</a></li>
        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
            <li class="nav-item"><a class="nav-link" href="{{ path('app_book_new') }}">+ Add Book</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}">Logout ({{ app.user.email }})</a></li>
        {% else %}
            <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">Login</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}">Register</a></li>
        {% endif %}
    </ul>
</nav>

{% for message in app.flashes('success') %}
    <div class="alert alert-success m-3">{{ message }}</div>
{% endfor %}

<div class="container mt-4">
    {% block body %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
